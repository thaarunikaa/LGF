<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Life Gap Finder</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Special+Elite&family=IBM+Plex+Mono:wght@400;500;600&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --cork: #11141c;
    --cork-dark: #0b0d13;
    --paper: #eef1e8;
    --paper-white: #f8faf3;
    --ink: #1c2420;
    --ink-soft: #55635a;
    --mustard: #d8a24a;
    --rust: #c65b4e;
    --teal: #4f9d8d;
    --slate: #6f8fae;
    --plum: #9574a0;
    --brass: #e3b869;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;height:100%;}
  body{
    background: var(--cork);
    background-image: radial-gradient(rgba(216,162,74,0.05) 1px, transparent 1px);
    background-size: 3px 3px;
    color: var(--paper);
    font-family:'Inter', sans-serif;
    height:100vh;
    display:flex;
    overflow:hidden;
  }
  ::-webkit-scrollbar{ width:9px; height:9px; }
  ::-webkit-scrollbar-thumb{ background: rgba(238,241,232,0.2); border-radius:6px; }

  /* ===== Auth gate ===== */
  .auth-gate{
    position:fixed; inset:0;
    background:
      radial-gradient(ellipse at 30% 20%, rgba(216,162,74,0.08), transparent 55%),
      var(--cork-dark);
    display:flex; align-items:center; justify-content:center;
    z-index: 100;
    padding: 20px;
  }
  .auth-card{
    width: 100%;
    max-width: 380px;
    background: var(--paper);
    color: var(--ink);
    border-radius: 6px;
    padding: 28px 26px 24px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.5);
  }
  .auth-stamp{
    font-family:'Special Elite', monospace;
    font-size: 19px;
    letter-spacing: 1px;
    margin-bottom: 8px;
  }
  .auth-sub{
    font-size: 12.5px;
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0 0 18px;
  }
  .auth-card label{
    display:block;
    font-size: 11px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin: 12px 0 6px;
  }
  .auth-card input{
    width:100%;
    background: var(--paper-white);
    border: 1px solid rgba(28,36,32,0.15);
    border-radius: 4px;
    padding: 10px 12px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    color: var(--ink);
  }
  .auth-card input:focus{ outline: 2px solid var(--mustard); border-color: transparent; }
  .auth-error{
    color: var(--rust);
    font-size: 12px;
    min-height: 16px;
    margin-top: 10px;
  }
  .auth-submit{
    width:100%;
    margin-top: 6px;
    background: var(--rust);
    color: var(--paper-white);
    border:none;
    border-radius:4px;
    padding: 12px 16px;
    font-weight:600;
    font-size: 13.5px;
    cursor:pointer;
  }
  .auth-submit:active{ transform: translateY(1px); }
  .auth-note{
    font-size: 11px;
    line-height: 1.5;
    color: var(--ink-soft);
    margin-top: 12px;
  }

  /* ===== App shell ===== */
  .app-root{ display:none; width:100%; height:100%; overflow:hidden; }
  .app-root.visible{ display:flex; }

  /* ===== Sidebar ===== */
  .sidebar{
    width: 250px;
    flex-shrink:0;
    background: var(--cork-dark);
    border-right: 1px solid rgba(238,241,232,0.12);
    display:flex;
    flex-direction:column;
    padding: 22px 16px;
  }
  .brand{
    font-family:'Special Elite', monospace;
    font-size: 20px;
    letter-spacing: 1px;
    padding: 4px 4px 2px;
    transform: rotate(-0.5deg);
  }
  .brand-sub{
    font-family:'IBM Plex Mono', monospace;
    font-size: 10.5px;
    letter-spacing: 1.5px;
    text-transform:uppercase;
    color: var(--mustard);
    margin: 4px 0 26px 4px;
  }
  nav{ display:flex; flex-direction:column; gap:8px; }
  .navbtn{
    display:flex;
    align-items:flex-start;
    gap:10px;
    text-align:left;
    background: transparent;
    border: 1px solid transparent;
    border-radius: 5px;
    padding: 11px 12px;
    cursor:pointer;
    color: rgba(238,241,232,0.75);
    transition: background .15s ease, border-color .15s ease;
  }
  .navbtn:hover{ background: rgba(238,241,232,0.06); }
  .navbtn.active{
    background: var(--paper);
    color: var(--ink);
    border-color: var(--rust);
  }
  .navbtn .dot{
    width:9px; height:9px; border-radius:50%;
    margin-top:5px; flex-shrink:0;
    background: var(--mustard);
  }
  .navbtn.active .dot{ background: var(--rust); }
  .navbtn .navtext b{
    display:block;
    font-size: 13.5px;
    font-weight:600;
  }
  .navbtn .navtext span{
    display:block;
    font-size: 11px;
    line-height:1.4;
    margin-top:2px;
    opacity:0.75;
  }
  .navbtn.active .navtext span{ color: var(--ink-soft); opacity:1; }

  .sidebar-foot{
    margin-top:auto;
    font-family:'IBM Plex Mono', monospace;
    font-size: 10.5px;
    line-height:1.6;
    color: rgba(238,241,232,0.45);
    border-top: 1px dashed rgba(238,241,232,0.15);
    padding-top: 14px;
  }
  .sidebar-foot .voice-code{ color: var(--brass); }
  .clear-link{
    display:inline-block;
    margin-top:8px;
    color: var(--rust);
    cursor:pointer;
    text-decoration: underline;
    font-size: 10.5px;
  }

  /* ===== Main ===== */
  main{ flex:1; min-width:0; display:flex; flex-direction:column; overflow:hidden; }
  .panel{ display:none; flex-direction:column; height:100%; overflow:hidden; }
  .panel.active{ display:flex; }
  .panel-head{
    padding: 20px 28px 14px;
    border-bottom: 1px dashed rgba(238,241,232,0.2);
    flex-shrink:0;
  }
  .panel-head h1{
    font-family:'Special Elite', monospace;
    font-size: 21px;
    margin: 0 0 5px;
  }
  .panel-head p{
    font-size: 12.5px;
    color: rgba(238,241,232,0.6);
    margin:0;
    max-width: 640px;
    line-height:1.5;
  }

  /* ===== TAB 1: Chat ===== */
  .chat-scroll{
    flex:1;
    overflow-y:auto;
    padding: 20px 28px;
    display:flex;
    flex-direction:column;
    gap:14px;
  }
  .msg{ max-width: 66%; }
  .msg.user{ align-self:flex-end; }
  .msg.assistant{ align-self:flex-start; }
  .bubble{
    padding: 11px 14px;
    border-radius: 4px;
    font-size: 13.5px;
    line-height:1.55;
  }
  .msg.user .bubble{
    background: var(--paper);
    color: var(--ink);
    font-family:'IBM Plex Mono', monospace;
    border-bottom-right-radius: 0;
  }
  .msg.assistant .bubble{
    background: rgba(238,241,232,0.08);
    border-left: 3px solid var(--brass);
    color: var(--paper);
    border-bottom-left-radius: 0;
  }
  .msg .meta{
    font-size: 10px;
    color: rgba(238,241,232,0.4);
    margin-top: 4px;
    font-family:'IBM Plex Mono', monospace;
  }
  .msg.user .meta{ text-align:right; }
  .pin-flag{
    display:inline-block;
    margin-top:6px;
    font-size: 10px;
    font-family:'IBM Plex Mono', monospace;
    color: var(--rust);
    letter-spacing:0.5px;
  }

  .context-row{
    padding: 10px 28px;
    border-top: 1px dashed rgba(238,241,232,0.15);
    flex-shrink:0;
  }
  .context-toggle{
    font-family:'IBM Plex Mono', monospace;
    font-size: 11px;
    color: var(--mustard);
    cursor:pointer;
    letter-spacing: 0.5px;
    user-select:none;
  }
  .context-fields{
    display:none;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    margin-top: 10px;
  }
  .context-fields.open{ display:grid; }
  .context-fields label{
    font-size: 10px;
    letter-spacing:0.5px;
    text-transform:uppercase;
    color: rgba(238,241,232,0.45);
    display:block;
    margin-bottom:4px;
  }
  .context-fields select, .context-fields input{
    width:100%;
    background: var(--paper);
    border:none;
    border-radius:3px;
    padding: 7px 8px;
    font-family:'IBM Plex Mono', monospace;
    font-size: 12px;
    color: var(--ink);
  }
  .context-note{
    font-size: 10.5px;
    color: rgba(238,241,232,0.4);
    margin-top: 8px;
    line-height:1.5;
  }

  .composer{
    display:flex;
    gap: 10px;
    padding: 14px 28px 20px;
    flex-shrink:0;
  }
  .composer input{
    flex:1;
    background: var(--paper);
    border:none;
    border-radius: 4px;
    padding: 12px 14px;
    font-family:'IBM Plex Mono', monospace;
    font-size: 13.5px;
    color: var(--ink);
  }
  .composer input:focus{ outline: 2px solid var(--brass); }
  .composer button{
    background: var(--rust);
    color: var(--paper-white);
    border:none;
    border-radius:4px;
    padding: 0 20px;
    font-weight:600;
    font-size: 13px;
    cursor:pointer;
  }
  .composer button:disabled{ opacity:0.5; cursor:not-allowed; }
  .typing{
    font-family:'IBM Plex Mono', monospace;
    font-size: 12px;
    color: var(--brass);
    padding: 0 28px 6px;
  }
  .typing::after{ content:''; animation: dots 1.2s steps(4,end) infinite; }
  @keyframes dots{ 0%{content:'';} 25%{content:'.';} 50%{content:'..';} 75%{content:'...';} 100%{content:'';} }

  /* ===== TAB 2: Ideas ===== */
  .ideas-body{ flex:1; overflow-y:auto; padding: 20px 28px 40px; }
  .scan-bar{
    display:flex; align-items:center; gap:14px;
    margin-bottom: 20px;
  }
  .btn-scan{
    background: var(--mustard);
    color: var(--cork-dark);
    border:none;
    border-radius:4px;
    padding: 11px 18px;
    font-family:'IBM Plex Mono', monospace;
    letter-spacing:1px;
    text-transform:uppercase;
    font-size: 12px;
    cursor:pointer;
    flex-shrink:0;
  }
  .btn-scan:disabled{ opacity:0.5; cursor:not-allowed; }
  .scan-note{ font-size:12px; color: rgba(238,241,232,0.5); }
  .clusters-grid{
    display:grid;
    grid-template-columns: repeat(auto-fill, minmax(300px,1fr));
    gap: 16px;
  }
  .clusterfile{
    background: var(--paper);
    color: var(--ink);
    border-radius:4px;
    padding: 18px 20px 20px;
    border-left: 6px solid var(--mustard);
    box-shadow: 0 6px 14px rgba(0,0,0,0.35);
  }
  .clusterfile .badge{
    font-family:'IBM Plex Mono', monospace;
    font-size:10.5px; letter-spacing:1px; text-transform:uppercase;
    color: var(--ink-soft); margin-bottom:8px;
    display:flex; justify-content:space-between;
  }
  .clusterfile h3{ font-family:'Special Elite', monospace; font-size:18px; margin:0 0 8px; line-height:1.3; }
  .clusterfile .insight{ font-size:13px; line-height:1.55; margin:0 0 12px; }
  .clusterfile .field{ font-size:11.5px; margin:8px 0; line-height:1.5; }
  .clusterfile .field b{ display:block; font-size:10px; letter-spacing:1px; text-transform:uppercase; color: var(--ink-soft); margin-bottom:2px; }
  .difficulty{
    display:inline-block;
    font-size:10px; letter-spacing:0.5px; text-transform:uppercase;
    padding: 2px 8px; border-radius:20px;
    background: rgba(36,27,21,0.08);
  }
  .pitch{ margin-top:12px; padding:10px 12px; background: rgba(36,27,21,0.06); border-radius:3px; font-size:12.5px; }
  .score-pins{ display:flex; gap:4px; margin-top:4px; }
  .score-pins span{ width:9px; height:9px; border-radius:50%; background: rgba(36,27,21,0.15); }
  .score-pins span.on{ background: var(--rust); }
  .empty-state{
    text-align:center; color: rgba(238,241,232,0.35);
    font-family:'IBM Plex Mono', monospace; font-size:13px;
    padding: 60px 20px;
  }

  /* ===== TAB 3: Dashboard ===== */
  .dash-body{ flex:1; overflow-y:auto; padding: 20px 28px 50px; }
  .privacy-notice{
    background: rgba(79,157,141,0.14);
    border: 1px solid var(--teal);
    border-radius: 5px;
    padding: 14px 16px;
    margin-bottom: 22px;
    font-size: 12px;
    line-height:1.6;
    color: rgba(238,241,232,0.85);
  }
  .privacy-notice b{ color: var(--teal); }
  .stat-row{
    display:grid;
    grid-template-columns: repeat(auto-fit, minmax(140px,1fr));
    gap: 12px;
    margin-bottom: 26px;
  }
  .stat-card{
    background: rgba(238,241,232,0.06);
    border: 1px solid rgba(238,241,232,0.12);
    border-radius: 5px;
    padding: 14px 16px;
  }
  .stat-card .num{ font-family:'Special Elite', monospace; font-size: 26px; }
  .stat-card .lbl{ font-size: 10.5px; letter-spacing:0.5px; text-transform:uppercase; color: rgba(238,241,232,0.5); margin-top:2px; }

  .chart-block{ margin-bottom: 30px; }
  .chart-block h3{
    font-family:'IBM Plex Mono', monospace;
    font-size: 12.5px; letter-spacing:1px; text-transform:uppercase;
    color: var(--brass); margin: 0 0 12px;
  }
  .bar-row{ display:flex; align-items:center; gap:10px; margin-bottom:8px; }
  .bar-label{ width: 150px; flex-shrink:0; font-size: 12px; font-family:'IBM Plex Mono', monospace; }
  .bar-track{ flex:1; background: rgba(238,241,232,0.08); border-radius:3px; height: 18px; overflow:hidden; }
  .bar-fill{ height:100%; border-radius:3px; }
  .bar-count{ width: 34px; text-align:right; font-size:11.5px; color: rgba(238,241,232,0.6); font-family:'IBM Plex Mono', monospace; }
  .suppressed-note{
    font-size: 11px; color: rgba(238,241,232,0.4); margin-top: 6px;
    font-family:'IBM Plex Mono', monospace;
  }

  .pattern-table{
    width:100%;
    border-collapse: collapse;
    font-size: 12.5px;
  }
  .pattern-table th{
    text-align:left;
    font-family:'IBM Plex Mono', monospace;
    font-size: 10.5px; text-transform:uppercase; letter-spacing:0.5px;
    color: rgba(238,241,232,0.5);
    padding: 8px 10px;
    border-bottom: 1px solid rgba(238,241,232,0.15);
  }
  .pattern-table td{
    padding: 10px 10px;
    border-bottom: 1px dashed rgba(238,241,232,0.1);
    vertical-align: top;
  }
  .tagchip{
    display:inline-block;
    font-size: 10.5px;
    padding: 2px 8px;
    border-radius: 20px;
    background: rgba(238,241,232,0.1);
    margin: 2px 4px 2px 0;
  }

  @media (max-width: 820px){
    .sidebar{ width: 90px; padding: 16px 8px; }
    .brand, .brand-sub, .navtext span{ display:none; }
    .navbtn{ justify-content:center; }
    .navbtn .navtext b{ font-size:0; }
    .navbtn .navtext b::before{ content: attr(data-short); font-size:10px; }
  }
  @media (prefers-reduced-motion: reduce){ *{ transition:none !important; } .typing::after{ animation:none; content:'...'; } }
</style>
</head>
<body>

<div class="auth-gate" id="authGate">
  <form class="auth-card" id="authForm">
    <div class="auth-stamp">LIFE GAP FINDER</div>
    <p class="auth-sub">Quick sign-in before you start. This is just so you have an account — what you share still goes into the board under an anonymous code, never your name.</p>

    <label for="authName">Full name</label>
    <input type="text" id="authName" placeholder="e.g. Priya Sharma" required>

    <label for="authContact">Email or phone number</label>
    <input type="text" id="authContact" placeholder="e.g. priya@email.com or +91 98765 43210" required>

    <div class="auth-error" id="authError"></div>
    <button type="submit" class="auth-submit">Continue</button>
    <div class="auth-note">Your name and contact are only used to sign you in — they're never attached to anything shown on the Ideas or Dashboard tabs.</div>
  </form>
</div>

<div class="app-root" id="appRoot">

<div class="sidebar">
  <div class="brand">LIFE GAP<br>FINDER</div>
  <div class="brand-sub">Anonymous Frustration Intake</div>
  <nav>
    <button class="navbtn active" data-tab="share">
      <span class="dot"></span>
      <span class="navtext"><b data-short="Share">Share a Problem</b><span>Chat with the intake AI</span></span>
    </button>
    <button class="navbtn" data-tab="ideas">
      <span class="dot"></span>
      <span class="navtext"><b data-short="Ideas">Hackathon Ideas</b><span>Problem statements from patterns</span></span>
    </button>
    <button class="navbtn" data-tab="dash">
      <span class="dot"></span>
      <span class="navtext"><b data-short="Dash">Privacy Dashboard</b><span>Aggregate trends, never raw quotes</span></span>
    </button>
  </nav>
  <div class="sidebar-foot">
    Signed in as <span class="voice-code" id="acctNameLabel">—</span><br>
    Shared problems are logged under <span class="voice-code" id="voiceCodeLabel">Voice #000</span>, not your name.
    <div class="clear-link" id="clearLink">Clear my session data</div>
    <div class="clear-link" id="signOutLink">Sign out</div>
  </div>
</div>

<main>

  <!-- TAB 1: SHARE -->
  <section class="panel active" id="panel-share">
    <div class="panel-head">
      <h1>Tell the AI what's bugging you</h1>
      <p>Describe something small that keeps happening to you. The AI never guesses your age, location, or job from what you type — those only get attached if you fill in the optional fields below before sending.</p>
    </div>
    <div class="chat-scroll" id="chatScroll"></div>
    <div class="typing" id="typingNote" style="visibility:hidden;">Gap is thinking</div>
    <div class="context-row">
      <div class="context-toggle" id="ctxToggle">+ Add anonymous context (optional)</div>
      <div class="context-fields" id="ctxFields">
        <div>
          <label>Age range</label>
          <select id="ctxAge">
            <option value="">Prefer not to say</option>
            <option>Under 18</option>
            <option>18-24</option>
            <option>25-34</option>
            <option>35-44</option>
            <option>45-54</option>
            <option>55+</option>
          </select>
        </div>
        <div>
          <label>Field / domain</label>
          <select id="ctxDomain">
            <option value="">Prefer not to say</option>
            <option>Student</option>
            <option>Tech/Software</option>
            <option>Healthcare</option>
            <option>Education</option>
            <option>Retail/Service</option>
            <option>Finance</option>
            <option>Parenting/Caregiving</option>
            <option>Creative/Media</option>
            <option>Other</option>
          </select>
        </div>
        <div>
          <label>Broad area</label>
          <input type="text" id="ctxRegion" placeholder="e.g. Urban, Suburban, Rural">
        </div>
      </div>
      <div class="context-note">These stay attached only as broad categories — never exact age, GPS, or employer — and are only ever shown in the app as grouped totals of 3 or more people.</div>
    </div>
    <div class="composer">
      <input type="text" id="chatInput" placeholder="Type a frustration, e.g. 'My bus app always says 3 minutes for 15 minutes straight'">
      <button id="sendBtn">Send</button>
    </div>
  </section>

  <!-- TAB 2: IDEAS -->
  <section class="panel" id="panel-ideas">
    <div class="panel-head">
      <h1>Hackathon Problem Statements</h1>
      <p>The AI looks across everything shared in this app — your messages plus prior anonymous submissions — and surfaces the frustrations that repeat across different people. Each pattern becomes a ready-to-pitch problem statement.</p>
    </div>
    <div class="ideas-body">
      <div class="scan-bar">
        <button class="btn-scan" id="scanBtn">Generate Problem Statements</button>
        <div class="scan-note" id="scanNote">Looking across everything shared in the system so far.</div>
      </div>
      <div id="ideasContent"></div>
    </div>
  </section>

  <!-- TAB 3: DASHBOARD -->
  <section class="panel" id="panel-dash">
    <div class="panel-head">
      <h1>Privacy Dashboard</h1>
      <p>Aggregate view of who's affected by what — never a raw quote tied to a person. Any group smaller than 3 reports is folded into "Other" so no individual can be singled out.</p>
    </div>
    <div class="dash-body" id="dashBody"></div>
  </section>

</main>

</div>

<script>
(function(){
  const PALETTE = ['#d8a24a','#4f9d8d','#6f8fae','#9574a0','#c65b4e'];
  const K_THRESHOLD = 3; // minimum group size to display individually

  const sessionVoice = 'Voice #' + (400 + Math.floor(Math.random()*599));
  document.getElementById('voiceCodeLabel').textContent = sessionVoice;

  // ================= AUTH GATE =================
  const authGate = document.getElementById('authGate');
  const authForm = document.getElementById('authForm');
  const authError = document.getElementById('authError');
  const appRoot = document.getElementById('appRoot');

  authForm.addEventListener('submit', function(e){
    e.preventDefault();
    const name = document.getElementById('authName').value.trim();
    const contact = document.getElementById('authContact').value.trim();
    const looksValid = contact.includes('@') || contact.replace(/\D/g,'').length >= 7;

    if(!name){ authError.textContent = 'Please enter your name.'; return; }
    if(!looksValid){ authError.textContent = 'Enter a valid email or a phone number (7+ digits).'; return; }

    authError.textContent = '';
    document.getElementById('acctNameLabel').textContent = name;
    authGate.style.display = 'none';
    appRoot.classList.add('visible');
    chatInput.focus();
  });

  document.getElementById('signOutLink').addEventListener('click', ()=>{
    appRoot.classList.remove('visible');
    authGate.style.display = 'flex';
    authForm.reset();
    authError.textContent = '';
  });

  // ---- seed data: prior anonymous submissions already in the system ----
  let problems = [
    {id:'s1',text:'Delivery food arrives cold because the driver stacks several stops before mine.',tag:'food-delivery',freq:'often',ageRange:'18-24',domain:'Student',region:'Urban',voice:'Voice #101'},
    {id:'s2',text:'I forget to refill my water bottle until I already have a headache.',tag:'health',freq:'daily',ageRange:'25-34',domain:'Tech/Software',region:'Urban',voice:'Voice #102'},
    {id:'s3',text:'Team chat threads bury decisions, so I re-explain them every meeting.',tag:'work',freq:'weekly',ageRange:'25-34',domain:'Tech/Software',region:'Urban',voice:'Voice #103'},
    {id:'s4',text:'Charging cables tangle in my bag every single day.',tag:'gadgets',freq:'daily',ageRange:'18-24',domain:'Student',region:'Urban',voice:'Voice #104'},
    {id:'s5',text:'I buy the wrong kid shoe size because sizing charts differ between brands.',tag:'parenting',freq:'monthly',ageRange:'35-44',domain:'Parenting/Caregiving',region:'Suburban',voice:'Voice #105'},
    {id:'s6',text:'Grocery apps show items in stock that are actually sold out at the store.',tag:'shopping',freq:'weekly',ageRange:'45-54',domain:'Retail/Service',region:'Suburban',voice:'Voice #106'},
    {id:'s7',text:'I forget medication because the reminder blends into all my other alarms.',tag:'health',freq:'daily',ageRange:'55+',domain:'Healthcare',region:'Rural',voice:'Voice #107'},
    {id:'s8',text:'Standup meetings run long because nobody tracks the time.',tag:'work',freq:'daily',ageRange:'25-34',domain:'Tech/Software',region:'Urban',voice:'Voice #108'},
    {id:'s9',text:'I forget to log small expenses so my budget app is always wrong.',tag:'finance',freq:'weekly',ageRange:'18-24',domain:'Student',region:'Urban',voice:'Voice #109'},
    {id:'s10',text:'The insurance portal logs me out halfway through every form.',tag:'finance',freq:'monthly',ageRange:'55+',domain:'Healthcare',region:'Rural',voice:'Voice #110'},
    {id:'s11',text:'School permission slips get lost in backpack chaos.',tag:'parenting',freq:'weekly',ageRange:'35-44',domain:'Parenting/Caregiving',region:'Suburban',voice:'Voice #111'},
    {id:'s12',text:'The register software crashes during the rush and I lose the sale.',tag:'work',freq:'weekly',ageRange:'45-54',domain:'Retail/Service',region:'Suburban',voice:'Voice #112'},
  ];
  let lastResult = {
    clusters: [
      {
        id:'c1', title:'Meds Lost In The Noise', entryIds:['s2','s7'],
        insight:'Health reminders compete with dozens of other alarms and get tuned out.',
        problemStatement:'Design a way for people to get health reminders that stand out from routine phone noise, without extra apps to manage.',
        targetUser:'Older adults, caregivers', opportunityScore:4,
        techDirection:'Distinct wearable or smart-speaker cue', difficulty:'Intermediate',
        pitchHook:'A reminder you can\'t accidentally swipe away.'
      },
      {
        id:'c2', title:'Meetings That Repeat Themselves', entryIds:['s3','s8'],
        insight:'Decisions and time both get lost inside chat threads and unstructured standups.',
        problemStatement:'Build a lightweight tool that captures meeting decisions and keeps standups on time without adding process overhead.',
        targetUser:'Small remote/hybrid teams', opportunityScore:3,
        techDirection:'Chat-bot summarizer with timer', difficulty:'Beginner',
        pitchHook:'Never re-explain a decision again.'
      },
      {
        id:'c3', title:'Budgets Built On Guesses', entryIds:['s9','s10'],
        insight:'Small spends and clunky portals both cause people to abandon tracking their money accurately.',
        problemStatement:'Create a frictionless way to capture small daily expenses and survive slow institutional portals without losing data.',
        targetUser:'Students, fixed-income adults', opportunityScore:4,
        techDirection:'One-tap capture with autosave', difficulty:'Beginner',
        pitchHook:'Budgeting that survives real life.'
      },
      {
        id:'c4', title:'Paper Chaos At Home', entryIds:['s5','s11'],
        insight:'Physical paperwork and inconsistent sizing standards create repeat friction for parents.',
        problemStatement:'Give parents one place to track kids\' sizes and school paperwork so nothing gets lost or mismatched again.',
        targetUser:'Parents of school-age kids', opportunityScore:3,
        techDirection:'Shared family mobile app', difficulty:'Beginner',
        pitchHook:'One backpack\'s worth of chaos, solved.'
      },
      {
        id:'c5', title:'Inventory That Lies', entryIds:['s6','s12'],
        insight:'Frontline retail software shows stale stock and crashes under real-world load, costing sales.',
        problemStatement:'Build resilient, real-time inventory and checkout software that stays accurate and stable during peak store traffic.',
        targetUser:'Retail staff and shoppers', opportunityScore:4,
        techDirection:'Real-time sync with offline fallback', difficulty:'Advanced',
        pitchHook:'Stock that\'s actually in stock.'
      }
    ],
    unclustered: ['s1','s4']
  }; // clustering result from the ideas tab — seeded with sample patterns so the tab isn't empty on first load

  // ================= TAB SWITCHING =================
  document.querySelectorAll('.navbtn').forEach(btn=>{
    btn.addEventListener('click', ()=>{
      document.querySelectorAll('.navbtn').forEach(b=>b.classList.remove('active'));
      document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('panel-'+btn.dataset.tab).classList.add('active');
      if(btn.dataset.tab==='dash') renderDashboard();
    });
  });

  document.getElementById('clearLink').addEventListener('click', ()=>{
    if(!confirm('Remove everything you personally shared in this session? Prior anonymous submissions from others stay.')) return;
    problems = problems.filter(p => p.voice !== sessionVoice);
    document.getElementById('chatScroll').innerHTML = '';
    seedGreeting();
    lastResult = null;
    renderIdeasEmpty();
    renderDashboard();
  });

  function escapeHtml(s){ const d=document.createElement('div'); d.textContent=s; return d.innerHTML; }

  // ================= TAB 1: CHAT =================
  const chatScroll = document.getElementById('chatScroll');
  const chatInput = document.getElementById('chatInput');
  const sendBtn = document.getElementById('sendBtn');
  const typingNote = document.getElementById('typingNote');
  const ctxToggle = document.getElementById('ctxToggle');
  const ctxFields = document.getElementById('ctxFields');

  ctxToggle.addEventListener('click', ()=>{
    ctxFields.classList.toggle('open');
    ctxToggle.textContent = ctxFields.classList.contains('open') ? '− Hide anonymous context' : '+ Add anonymous context (optional)';
  });

  let chatHistory = []; // {role, content}

  function addBubble(role, text, pinned){
    const wrap = document.createElement('div');
    wrap.className = 'msg ' + role;
    const b = document.createElement('div');
    b.className = 'bubble';
    b.textContent = text;
    wrap.appendChild(b);
    const meta = document.createElement('div');
    meta.className = 'meta';
    meta.textContent = role === 'user' ? sessionVoice : 'Gap · intake assistant';
    wrap.appendChild(meta);
    if(pinned){
      const flag = document.createElement('div');
      flag.className = 'pin-flag';
      flag.textContent = '📌 pinned to the case board, anonymously';
      wrap.appendChild(flag);
    }
    chatScroll.appendChild(wrap);
    chatScroll.scrollTop = chatScroll.scrollHeight;
  }

  function seedGreeting(){
    addBubble('assistant', "Hi — I'm Gap. Tell me about something small that keeps annoying you, at home, work, or anywhere else. I'll never ask your name, and I won't guess your age or location — only what you type in the optional fields counts.");
  }
  seedGreeting();

  async function sendMessage(){
    const text = chatInput.value.trim();
    if(!text) return;
    chatInput.value = '';
    sendBtn.disabled = true;
    addBubble('user', text);
    chatHistory.push({role:'user', content:text});
    typingNote.style.visibility = 'visible';

    const systemPrompt = `You are Gap, a warm, brief intake assistant collecting small recurring daily frustrations for an anonymous research board. Keep replies to 1-2 sentences, sound genuinely curious, and ask at most one short follow-up question when it would help pin down specifics (how often, what exactly breaks).

Never ask for or guess the person's name, age, exact location, or employer. If the message is not really a recurring frustration (a greeting, thanks, small talk), set "problem" to null and just reply warmly.

Return ONLY raw JSON, no markdown fences, no extra text, matching exactly:
{
  "reply": "your short conversational reply",
  "problem": null OR {
    "text": "one clear sentence restating the recurring frustration in third person",
    "tag": "one of: food-delivery, health, work, parenting, shopping, gadgets, transport, finance, education, other",
    "freq": "daily|weekly|monthly|often|rarely"
  }
}`;

    try{
      const response = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-sonnet-4-6",
          max_tokens: 1000,
          system: systemPrompt,
          messages: chatHistory.slice(-8)
        })
      });
      if(!response.ok) throw new Error('status ' + response.status);
      const data = await response.json();
      const raw = (data.content||[]).map(b=>b.text||'').join('\n').trim();
      const cleaned = raw.replace(/^```json/i,'').replace(/^```/,'').replace(/```$/,'').trim();
      const parsed = JSON.parse(cleaned);

      chatHistory.push({role:'assistant', content: JSON.stringify(parsed)});

      let pinned = false;
      if(parsed.problem && parsed.problem.text){
        problems.push({
          id: 'u'+Date.now(),
          text: parsed.problem.text,
          tag: parsed.problem.tag || 'other',
          freq: parsed.problem.freq || 'often',
          ageRange: document.getElementById('ctxAge').value || '',
          domain: document.getElementById('ctxDomain').value || '',
          region: document.getElementById('ctxRegion').value.trim() || '',
          voice: sessionVoice
        });
        pinned = true;
      }
      addBubble('assistant', parsed.reply || "Got it, thanks for sharing.", pinned);
    }catch(err){
      console.error(err);
      addBubble('assistant', "I couldn't process that just now — mind trying again in a moment?");
    }finally{
      typingNote.style.visibility = 'hidden';
      sendBtn.disabled = false;
      chatInput.focus();
    }
  }

  sendBtn.addEventListener('click', sendMessage);
  chatInput.addEventListener('keydown', e=>{ if(e.key==='Enter') sendMessage(); });

  // ================= TAB 2: IDEAS =================
  const scanBtn = document.getElementById('scanBtn');
  const scanNote = document.getElementById('scanNote');
  const ideasContent = document.getElementById('ideasContent');
  function renderIdeasEmpty(){
    ideasContent.innerHTML = '<div class="empty-state">No patterns generated yet. Share a few problems, then run the scan.</div>';
  }

  scanBtn.addEventListener('click', async ()=>{
    if(problems.length < 3){
      scanNote.textContent = 'Need at least 3 problems in the system before scanning.';
      return;
    }
    scanBtn.disabled = true;
    scanNote.textContent = 'Cross-referencing reports...';

    const payload = problems.map(p=>({id:p.id, text:p.text, tag:p.tag, freq:p.freq, ageRange:p.ageRange, domain:p.domain, region:p.region}));

    const systemPrompt = `You are a hackathon mentor who studies small recurring frustrations reported by many anonymous people and turns real repeating patterns into ready-to-build hackathon problem statements.

Group entries into clusters ONLY where at least 2 entries share a genuine underlying mechanism, not just the same tag label. Entries with no clear match go in "unclustered".

Return ONLY raw JSON, no markdown fences, no preamble, matching exactly:
{
  "clusters": [
    {
      "id": "c1",
      "title": "punchy 3-6 word pattern name",
      "entryIds": ["id1","id2"],
      "insight": "max 20 words on what's really going on underneath",
      "problemStatement": "max 22 words, formal problem statement a hackathon team could pitch",
      "targetUser": "max 6 words on who feels this most",
      "opportunityScore": 1,
      "techDirection": "max 8 words, a plausible tech angle (app, sensor, API, etc)",
      "difficulty": "Beginner|Intermediate|Advanced",
      "pitchHook": "max 14 words, one-line startup-style pitch"
    }
  ],
  "unclustered": ["id3"]
}
opportunityScore is an integer 1-5.`;

    try{
      const response = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-sonnet-4-6",
          max_tokens: 1000,
          system: systemPrompt,
          messages: [{role:"user", content: "Entries:\n" + JSON.stringify(payload)}]
        })
      });
      if(!response.ok) throw new Error('status ' + response.status);
      const data = await response.json();
      const raw = (data.content||[]).map(b=>b.text||'').join('\n').trim();
      const cleaned = raw.replace(/^```json/i,'').replace(/^```/,'').replace(/```$/,'').trim();
      const parsed = JSON.parse(cleaned);
      if(!parsed.clusters) throw new Error('malformed');

      lastResult = parsed;
      scanNote.textContent = parsed.clusters.length + ' pattern(s) found across common problem categories.';
      renderIdeas(parsed);
    }catch(err){
      console.error(err);
      scanNote.textContent = "That scan didn't come back clean — try again in a moment.";
    }finally{
      scanBtn.disabled = false;
    }
  });

  function renderIdeas(result){
    if(!result.clusters.length){ renderIdeasEmpty(); return; }
    ideasContent.innerHTML = '';
    const grid = document.createElement('div');
    grid.className = 'clusters-grid';
    result.clusters.forEach((c,i)=>{
      const color = PALETTE[i % PALETTE.length];
      const el = document.createElement('div');
      el.className = 'clusterfile';
      el.style.borderLeftColor = color;
      let pins='';
      for(let s=1;s<=5;s++) pins += `<span class="${s<=(c.opportunityScore||0)?'on':''}"></span>`;
      el.innerHTML = `
        <div class="badge"><span>Pattern ${i+1} · ${c.entryIds.length} reports</span><span class="difficulty">${escapeHtml(c.difficulty||'')}</span></div>
        <h3>${escapeHtml(c.title||'Untitled pattern')}</h3>
        <p class="insight">${escapeHtml(c.insight||'')}</p>
        <div class="field"><b>Problem statement</b>${escapeHtml(c.problemStatement||'')}</div>
        <div class="field"><b>Feels it most</b>${escapeHtml(c.targetUser||'')}</div>
        <div class="field"><b>Tech direction</b>${escapeHtml(c.techDirection||'')}</div>
        <div class="field"><b>Opportunity strength</b><div class="score-pins">${pins}</div></div>
        <div class="pitch">${escapeHtml(c.pitchHook||'')}</div>
      `;
      grid.appendChild(el);
    });
    ideasContent.appendChild(grid);
  }

  // ================= TAB 3: DASHBOARD =================
  function groupCounts(list, key){
    const m = {};
    list.forEach(p=>{
      const v = (p[key]||'').trim();
      if(!v) return;
      m[v] = (m[v]||0) + 1;
    });
    return m;
  }

  function renderBarChart(container, title, counts){
    const entries = Object.entries(counts);
    const shown = entries.filter(([k,v])=> v >= K_THRESHOLD).sort((a,b)=>b[1]-a[1]);
    const suppressed = entries.filter(([k,v])=> v < K_THRESHOLD);
    const suppressedTotal = suppressed.reduce((a,[k,v])=>a+v,0);
    const max = Math.max(1, ...shown.map(e=>e[1]), suppressedTotal);

    const block = document.createElement('div');
    block.className = 'chart-block';
    let html = `<h3>${escapeHtml(title)}</h3>`;
    if(shown.length === 0 && suppressedTotal === 0){
      html += `<div class="suppressed-note">No data yet.</div>`;
    }
    shown.forEach(([k,v], i)=>{
      const pct = Math.round((v/max)*100);
      html += `<div class="bar-row">
        <div class="bar-label">${escapeHtml(k)}</div>
        <div class="bar-track"><div class="bar-fill" style="width:${pct}%;background:${PALETTE[i%PALETTE.length]}"></div></div>
        <div class="bar-count">${v}</div>
      </div>`;
    });
    if(suppressedTotal > 0){
      const pct = Math.round((suppressedTotal/max)*100);
      html += `<div class="bar-row">
        <div class="bar-label">Other (small groups)</div>
        <div class="bar-track"><div class="bar-fill" style="width:${pct}%;background:rgba(238,241,232,0.25)"></div></div>
        <div class="bar-count">${suppressedTotal}</div>
      </div>
      <div class="suppressed-note">Groups under ${K_THRESHOLD} reports are combined here so no individual can be identified.</div>`;
    }
    block.innerHTML = html;
    container.appendChild(block);
  }

  function renderDashboard(){
    const body = document.getElementById('dashBody');
    body.innerHTML = '';

    const notice = document.createElement('div');
    notice.className = 'privacy-notice';
    notice.innerHTML = `<b>How this stays private:</b> demographic fields are optional and self-reported in broad buckets only (no exact age, no GPS, no employer name). Any breakdown with fewer than ${K_THRESHOLD} reports is folded into "Other" before it's shown here. Nothing on this tab is ever linked back to a message or a person — only totals. All of this data lives in your browser tab for this session and disappears on reload.`;
    body.appendChild(notice);

    const tagCounts = groupCounts(problems,'tag');
    const topCategory = Object.entries(tagCounts).sort((a,b)=>b[1]-a[1])[0];
    const tags = Object.keys(tagCounts).length;
    const stats = document.createElement('div');
    stats.className = 'stat-row';
    stats.innerHTML = `
      <div class="stat-card"><div class="num" style="font-size:18px;">${topCategory ? escapeHtml(topCategory[0]) : '—'}</div><div class="lbl">Most common category</div></div>
      <div class="stat-card"><div class="num">${tags}</div><div class="lbl">Categories tracked</div></div>
      <div class="stat-card"><div class="num">${lastResult ? lastResult.clusters.length : 0}</div><div class="lbl">Patterns found</div></div>
    `;
    body.appendChild(stats);

    renderBarChart(body, 'Problems by category', groupCounts(problems,'tag'));
    renderBarChart(body, 'Problems by age range', groupCounts(problems,'ageRange'));
    renderBarChart(body, 'Problems by domain', groupCounts(problems,'domain'));
    renderBarChart(body, 'Problems by area', groupCounts(problems,'region'));

    if(lastResult && lastResult.clusters.length){
      const h = document.createElement('h3');
      h.textContent = 'Which groups feel each pattern';
      h.style.cssText = "font-family:'IBM Plex Mono', monospace;font-size:12.5px;letter-spacing:1px;text-transform:uppercase;color:#e0b33e;margin:10px 0 12px;";
      body.appendChild(h);

      const table = document.createElement('table');
      table.className = 'pattern-table';
      let rows = '<tr><th>Pattern</th><th>Age ranges</th><th>Domains</th></tr>';
      lastResult.clusters.forEach(c=>{
        const members = c.entryIds.map(id=>problems.find(p=>p.id===id)).filter(Boolean);
        const ageCounts = groupCounts(members,'ageRange');
        const domainCounts = groupCounts(members,'domain');
        const ageChips = Object.entries(ageCounts).filter(([k,v])=>v>=2).map(([k,v])=>`<span class="tagchip">${escapeHtml(k)} · ${v}</span>`).join('') || '<span class="suppressed-note">insufficient data to disclose</span>';
        const domainChips = Object.entries(domainCounts).filter(([k,v])=>v>=2).map(([k,v])=>`<span class="tagchip">${escapeHtml(k)} · ${v}</span>`).join('') || '<span class="suppressed-note">insufficient data to disclose</span>';
        rows += `<tr><td><b>${escapeHtml(c.title||'')}</b></td><td>${ageChips}</td><td>${domainChips}</td></tr>`;
      });
      table.innerHTML = rows;
      body.appendChild(table);
    }
  }

  scanNote.textContent = lastResult.clusters.length + ' pattern(s) found across common problem categories.';
  renderIdeas(lastResult);
  renderDashboard();
})();
</script>
</body>
</html>

